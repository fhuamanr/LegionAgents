# Production Compose template.
# Copy to an untracked file and replace every placeholder before deployment.

APP_ENV=production
LOG_LEVEL=info

BACKEND_IMAGE=multi-agent-delivery-backend:latest
FRONTEND_IMAGE=multi-agent-delivery-frontend:latest
QA_SANDBOX_IMAGE=multi-agent-delivery-qa-sandbox:latest

BACKEND_PORT=8000
FRONTEND_PORT=3000

PUBLIC_API_BASE_URL=https://api.example.com
PUBLIC_WS_BASE_URL=wss://api.example.com

POSTGRES_USER=platform
POSTGRES_PASSWORD=change-me
POSTGRES_DB=platform
POSTGRES_DSN=postgresql://platform:change-me@postgres:5432/platform

REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

QDRANT_URL=http://qdrant:6333
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=ai-delivery-artifacts

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_CODEX_MODEL=gpt-5
OPENAI_BASE_URL=

OTEL_EXPORTER_OTLP_ENDPOINT=
DATADOG_API_KEY=
