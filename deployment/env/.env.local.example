# Local lightweight Compose defaults for deployment/compose/docker-compose.local.yml.

APP_ENV=local
LOG_LEVEL=debug

BACKEND_PORT=8000
FRONTEND_PORT=3000

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WS_BASE_URL=ws://127.0.0.1:8000

POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql://platform:platform@postgres:5432/platform

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_CODEX_MODEL=gpt-5
OPENAI_BASE_URL=

# Optional OpenAI-compatible providers. The provider UI can also persist these.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
LM_STUDIO_BASE_URL=http://host.docker.internal:1234
LM_STUDIO_MODEL=local-model
OPENAI_COMPATIBLE_PROVIDER_NAME=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

OTEL_EXPORTER_OTLP_ENDPOINT=
DATADOG_API_KEY=
