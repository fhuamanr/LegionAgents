# Local Docker Compose defaults.
# Copy this file to .env.compose for local overrides:
#   copy deployment\env\.env.compose.example .env.compose
#
# Do not put production secrets in this file.

APP_ENV=local
LOG_LEVEL=debug

# Public ports exposed on the host.
NGINX_PORT=8080
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
SELENIUM_PORT=4444
SELENIUM_VNC_PORT=7900

# Frontend integration through the Nginx reverse proxy.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080/api
NEXT_PUBLIC_WS_BASE_URL=ws://127.0.0.1:8080

# Local service credentials. These are development-only values.
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
MINIO_ROOT_USER=platform
MINIO_ROOT_PASSWORD=platform-secret
MINIO_BUCKET=ai-delivery-artifacts
SELENIUM_MAX_SESSIONS=2

# Backend service URLs inside the compose network.
REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql://platform:platform@postgres:5432/platform
QDRANT_URL=http://qdrant:6333
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=platform
MINIO_SECRET_KEY=platform-secret

# Optional model provider settings. Fill OPENAI_API_KEY locally when using real LLM execution.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_CODEX_MODEL=gpt-5
OPENAI_BASE_URL=

# Optional observability exporters.
OTEL_EXPORTER_OTLP_ENDPOINT=
DATADOG_API_KEY=
