flowchart TB
  User["User / Operator"] --> UI["Next.js Dashboard"]
  UI --> API["FastAPI Backend"]
  UI -. "exec stream" .-> WSExec["/ws/executions/{workflow_id}"]
  UI -. "telemetry stream" .-> WSTelemetry["/ws/workflows/{workflow_id}/telemetry"]

  API --> Providers["Provider Registry + Local Runtime Controls"]
  API --> PromptStudio["Prompt Studio"]
  API --> GovernanceUI["Governance Config UI"]
  API --> Playground["Agent Playground / Step Runner"]
  API --> WorkflowAPI["Workflow Trigger / Status / Reports"]
  API --> ArtifactAPI["Artifact Listing + Retrieval APIs"]

  WorkflowAPI --> LangGraph["LangGraph Execution Runtime"]
  LangGraph --> Router["Stage Router + Execution Modes"]
  Router --> BA["BA Agent"]
  BA --> Architect["Architect Agent"]
  Architect --> Developer["Developer Agent"]
  Developer --> QA["QA Agent"]
  QA --> Docs["Docs Agent"]
  Docs --> PR["PR Agent"]

  LangGraph --> Governor["Context Governor"]
  Governor --> Budgets["Per-Agent Prompt/Output/Handoff Budgets"]
  Governor --> Compression["Handoff Compression + Stage Summaries"]

  LangGraph --> Runtime["Agent Runtime"]
  Runtime --> PromptBuilder["Prompt Builder"]
  Runtime --> OutputRepair["Output Extraction + Repair + Normalization"]
  Runtime --> Governance["Governance Validation + Severity Modes"]
  Runtime --> Retry["Deterministic Retry Classifier"]

  Governance --> AutoRepair["Fixable Governance Auto-Repair"]
  AutoRepair --> Revalidate["Revalidate Repaired Artifacts"]

  Providers --> LocalLM["LM Studio / Ollama / Local OAI-Compatible"]
  Providers --> CloudLLM["OpenAI / OpenRouter / Remote OAI-Compatible"]
  Runtime --> LocalLM
  Runtime --> CloudLLM

  Runtime --> RepoOps["Repository Runtime (optional)"]
  RepoOps --> GitOps["Clone / Branch / Modify / Diff / Commit"]

  Runtime --> ArtifactWriter["Artifact Persistence Layer"]
  ArtifactWriter --> ArtifactTree["data/artifacts/{workflow_id}/{agent}/..."]
  ArtifactWriter --> Reports["Resolution / Completeness / Quality / Governance Reports"]
  ArtifactAPI --> ArtifactTree

  API --> Persistence["PostgreSQL JSONB Persistence"]
  Persistence --> WorkflowState["Workflow Records + Checkpoints"]
  Persistence --> PromptState["Prompt Versions"]
  Persistence --> GovernanceState["Governance Versions"]
  Persistence --> ProviderState["Provider + Model Profiles"]

  Worker["Recovery Worker"] --> Persistence
  Worker --> LangGraph

